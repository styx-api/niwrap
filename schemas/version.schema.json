{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://niwrap.org/schemas/version.schema.json",
  "title": "NiWrap Version Schema",
  "description": "Version-specific metadata",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Version identifier (matches directory name)"
    },
    "container": {
      "type": "string",
      "description": "Container image reference (e.g., Docker image with tag)"
    },
    "apps": {
      "type": "array",
      "description": "List of wrapped applications",
      "items": {
        "type": "string"
      }
    },
    "executables": {
      "type": "object",
      "description": "Executable validation lists",
      "properties": {
        "required": {
          "type": "array",
          "description": "Executables that must exist in container (validated in CI)",
          "items": {
            "type": "string"
          }
        },
        "ignored": {
          "type": "array",
          "description": "Executables explicitly not wrapped",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "array",
      "description": "Upstream source repositories used to generate this version's descriptors, pinned to match the container build.",
      "items": {
        "type": "object",
        "required": ["repo", "role"],
        "properties": {
          "repo": {
            "type": "string",
            "format": "uri",
            "description": "Git clone URL (.git)"
          },
          "ref": {
            "type": ["string", "null"],
            "description": "Pinned git ref (tag, branch, or commit SHA). null means unpinned (clone the default branch)."
          },
          "role": {
            "type": "string",
            "enum": ["primary", "dependency"],
            "description": "primary: the tool's own source code. dependency: a supporting repo (e.g. ITK for ANTs) read for type/output context during descriptor generation."
          },
          "note": {
            "type": "string",
            "description": "Optional rationale: why a dependency is included, or how/why a ref was chosen."
          }
        },
        "additionalProperties": false
      }
    },
    "release_date": {
      "type": "string",
      "format": "date",
      "description": "Release date (ISO 8601 format)"
    },
    "deprecated": {
      "type": "boolean",
      "description": "Whether this version is deprecated",
      "default": false
    },
    "docs": {
      "type": "object",
      "description": "Version-specific documentation",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "description": "Version notes or changelog"
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "literature": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "urls": {
          "type": "array",
          "description": "Version-specific URLs (changelog, release notes, etc.)",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  },
  "additionalProperties": true
}